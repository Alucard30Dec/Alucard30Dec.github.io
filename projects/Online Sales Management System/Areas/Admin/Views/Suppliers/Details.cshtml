@model OnlineSalesManagementSystem.Areas.Admin.Controllers.SuppliersController.SupplierDetailsVm
@using OnlineSalesManagementSystem.Domain.Entities
@{
    ViewData["Title"] = "Chi tiết Nhà cung cấp";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    
    var s = Model.Supplier;
    var firstLetter = string.IsNullOrEmpty(s.Name) ? "S" : s.Name.Substring(0, 1).ToUpper();
}

<link rel="stylesheet" href="~/css/suppliers.css" asp-append-version="true" />

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1 text-dark">Hồ sơ Nhà cung cấp</h1>
            <p class="text-muted small mb-0">Xem chi tiết thông tin đối tác và lịch sử giao dịch.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-light border shadow-sm rounded-pill px-3" href="/Admin/Suppliers">
                <i class="fa fa-arrow-left me-2"></i>Quay lại
            </a>
            <a class="btn btn-warning text-white shadow-sm rounded-pill px-3 fw-bold" href="/Admin/Suppliers/Edit/@s.Id">
                <i class="fa fa-edit me-2"></i>Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card card-modern h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="avatar-supplier" style="width: 80px; height: 80px; font-size: 2rem; border-radius: 20px;">
                            @firstLetter
                        </div>
                    </div>
                    
                    <h5 class="fw-bold text-dark mb-1">@s.Name</h5>
                    <div class="text-muted small mb-4">ID Đối tác: #@s.Id</div>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <a href="tel:@s.Phone" class="btn btn-light border rounded-pill px-3 btn-sm">
                            <i class="fa fa-phone text-warning me-1"></i> Gọi điện
                        </a>
                        <a href="mailto:@s.Email" class="btn btn-light border rounded-pill px-3 btn-sm">
                            <i class="fa fa-envelope text-secondary me-1"></i> Gửi Email
                        </a>
                    </div>

                    <div class="border-top pt-3 text-start">
                        <h6 class="text-uppercase text-muted small fw-bold mb-3">Thông tin liên hệ</h6>
                        <div class="mb-3">
                            <label class="small text-muted mb-1 d-block">Số điện thoại</label>
                            <span class="fw-bold text-dark">@(string.IsNullOrEmpty(s.Phone) ? "---" : s.Phone)</span>
                        </div>
                        <div class="mb-3">
                            <label class="small text-muted mb-1 d-block">Email</label>
                            <span class="fw-bold text-dark">@(string.IsNullOrEmpty(s.Email) ? "---" : s.Email)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card card-modern border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom p-4">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fa fa-info-circle me-2 text-warning"></i>Thông tin chi tiết</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-5">
                        <label class="small text-muted mb-1 text-uppercase fw-bold">Địa chỉ văn phòng / Kho hàng</label>
                        <div class="p-3 bg-light rounded-3 border">
                            <i class="fa fa-map-marker text-danger opacity-75 me-2"></i>
                            <span class="fw-semibold text-dark">@(string.IsNullOrEmpty(s.Address) ? "Chưa cập nhật địa chỉ." : s.Address)</span>
                        </div>
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <label class="small text-muted mb-0 text-uppercase fw-bold">Lịch sử nhập hàng gần đây</label>
                            @if(Model.History.Any()) {
                                <span class="badge bg-light text-secondary border">@Model.History.Count phiếu</span>
                            }
                        </div>
                        
                        <div class="table-responsive">
                            <table class="table table-modern table-bordered mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Mã phiếu</th>
                                        <th>Ngày nhập</th>
                                        <th class="text-end">Tổng tiền</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th class="text-center">#</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.History.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted small">
                                                <i class="fa fa-box-open mb-2 d-block fa-2x opacity-25"></i>
                                                Chưa có dữ liệu nhập hàng từ nhà cung cấp này.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var item in Model.History)
                                        {
                                            // Xử lý màu sắc trạng thái
                                            string badgeClass = item.Status switch {
                                                PurchaseStatus.Received => "bg-success text-white", // Đã nhập
                                                PurchaseStatus.Cancelled => "bg-danger text-white", // Đã hủy
                                                _ => "bg-secondary text-white" // Nháp
                                            };
                                            string statusLabel = item.Status switch {
                                                PurchaseStatus.Received => "Đã nhập kho",
                                                PurchaseStatus.Cancelled => "Đã hủy",
                                                _ => "Bản nháp"
                                            };

                                            <tr>
                                                <td class="fw-bold text-primary">
                                                    <a href="/Admin/Purchases/Details/@item.PurchaseId" class="text-decoration-none">
                                                        @item.PurchaseNo
                                                    </a>
                                                </td>
                                                <td>@item.PurchaseDate.ToString("dd/MM/yyyy")</td>
                                                <td class="text-end fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                                                <td class="text-center">
                                                    <span class="badge @badgeClass rounded-pill fw-normal px-3">@statusLabel</span>
                                                </td>
                                                <td class="text-center">
                                                    <a href="/Admin/Purchases/Details/@item.PurchaseId" class="btn btn-sm btn-light border" title="Xem chi tiết">
                                                        <i class="fa fa-arrow-right"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@model OnlineSalesManagementSystem.Areas.Admin.Controllers.ProductsController.ProductExcelPreviewVm

@{
    ViewData["Title"] = "Xem trước import Excel";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4" style="background-color:#f8f9fc;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h3 class="fw-bold mb-1">Xem trước dữ liệu import</h3>
                    <div class="text-muted">Chỉ những dòng <b>hợp lệ</b> mới được import. Dòng lỗi sẽ hiển thị lý do.</div>
                </div>
                <div class="d-flex gap-2">
                    <a class="btn btn-outline-secondary" href="/Admin/Products/ImportExcel"><i class="fas fa-arrow-left me-1"></i> Upload lại</a>
                    <a class="btn btn-outline-primary" href="/Admin/Products"><i class="fas fa-list me-1"></i> Danh sách</a>
                </div>
            </div>
        </div>

        <div class="card-body px-4 pb-4">
            <div class="row g-3">
                <div class="col-12 col-lg-4">
                    <div class="p-3 bg-light rounded">
                        <div class="fw-semibold">Tổng dòng</div>
                        <div class="fs-4 fw-bold">@Model.TotalRows</div>
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="p-3 bg-success-subtle rounded">
                        <div class="fw-semibold">Hợp lệ</div>
                        <div class="fs-4 fw-bold text-success">@Model.ValidRows</div>
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="p-3 bg-danger-subtle rounded">
                        <div class="fw-semibold">Lỗi</div>
                        <div class="fs-4 fw-bold text-danger">@Model.InvalidRows</div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-4" style="max-height: 520px; overflow:auto;">
                <table class="table table-sm align-middle table-hover">
                    <thead class="table-light" style="position:sticky; top:0; z-index:2;">
                        <tr>
                            <th>#</th>
                            <th>SKU</th>
                            <th>Tên</th>
                            <th>Danh mục</th>
                            <th>Đơn vị</th>
                            <th>Brand</th>
                            <th class="text-end">Giá nhập</th>
                            <th class="text-end">Giá bán</th>
                            <th class="text-end">Tồn kho</th>
                            <th class="text-center">Active</th>
                            <th class="text-center">Trending</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Rows)
                        {
                            <tr class="@(r.IsValid ? "" : "table-danger")">
                                <td class="text-muted">@r.RowNo</td>
                                <td class="fw-semibold">@r.SKU</td>
                                <td>@r.Name</td>
                                <td>
                                    @if (r.ResolvedCategoryId.HasValue)
                                    {
                                        <span class="badge bg-success">@r.ResolvedCategoryId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    <div class="small text-muted">@(!string.IsNullOrWhiteSpace(r.CategoryName) ? r.CategoryName : "")</div>
                                </td>
                                <td>
                                    @if (r.ResolvedUnitId.HasValue)
                                    {
                                        <span class="badge bg-success">@r.ResolvedUnitId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    <div class="small text-muted">@(!string.IsNullOrWhiteSpace(r.UnitName) ? r.UnitName : "")</div>
                                </td>
                                <td>
                                    @if (r.ResolvedBrandId.HasValue)
                                    {
                                        <span class="badge bg-success">@r.ResolvedBrandId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    <div class="small text-muted">@(!string.IsNullOrWhiteSpace(r.BrandName) ? r.BrandName : "")</div>
                                </td>
                                <td class="text-end">@(r.CostPrice.HasValue ? r.CostPrice.Value.ToString("N0") : "")</td>
                                <td class="text-end">@(r.SalePrice.HasValue ? r.SalePrice.Value.ToString("N0") : "")</td>
                                <td class="text-end">@(r.StockOnHand.HasValue ? r.StockOnHand.Value.ToString() : "")</td>
                                <td class="text-center">@(r.IsActive.HasValue ? (r.IsActive.Value ? "✔" : "✖") : "")</td>
                                <td class="text-center">@(r.IsTrending.HasValue ? (r.IsTrending.Value ? "✔" : "✖") : "")</td>
                                <td>
                                    @if (r.IsValid)
                                    {
                                        <span class="badge bg-success">Hợp lệ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Lỗi</span>
                                        <div class="small mt-1">
                                            @foreach (var e in r.Errors)
                                            {
                                                <div>• @e</div>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <form method="post" action="/Admin/Products/ImportExcelConfirm" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="cacheKey" value="@Model.CacheKey" />

                <div class="d-flex flex-wrap gap-2 justify-content-end">
                    <a class="btn btn-outline-secondary" href="/Admin/Products/ImportExcel">Hủy</a>
                    <button type="submit" class="btn btn-success" @(Model.ValidRows == 0 ? "disabled" : "")>
                        <i class="fas fa-database me-1"></i> Import @Model.ValidRows dòng hợp lệ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
